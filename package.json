{
  "name": "playwright-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:e2e": "playwright test --grep @e2e",
    "test:smoke-headed": "playwright test --grep @smoke --headed",
    "test:regression-headed": "playwright test --grep @regression --headed",
    "test:e2e-headed": "playwright test --grep @e2e --headed",
    "test:critical": "playwright test --grep @priority:critical",
    "test:smoke:report": "npm run test:smoke && npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "test:regression:report": "npm run test:regression && npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "test:e2e:report": "npm run test:e2e && npx allure generate allure-results --clean -o allure-report && npx allure open allure-report",
    "test:feature:login": "playwright test --grep @login",
    "test:feature:cart": "playwright test --grep @cart",
    "test:feature:checkout": "playwright test --grep @checkout",
    "test:feature:payment": "playwright test --grep @payment",
    "test:feature:search": "playwright test --grep @search"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0"
  }
}
